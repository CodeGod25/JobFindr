   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# JobFindr Recommendation Logic Demo\n",
    "\n",
    "This notebook demonstrates the core machine learning and ranking algorithms powering **JobFindr**. We will walk through the three main strategy modes:\n",
    "\n",
    "1.  **TF-IDF Neural (Semantic)**: Uses cosine similarity between user profiles and job descriptions.\n",
    "2.  **Keyword Match**: Evaluates Jaccard token overlap between skills and titles.\n",
    "3.  **Hybrid**: A weighted combination of both semantic and keyword matching (0.7 × TF-IDF + 0.3 × Keyword).\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies (for Google Colab environment)\n",
    "!pip install scikit-learn pandas numpy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import re\n",
    "import string\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "\n",
    "# ── Define Preprocessing Logic (Mirroring app/ml/preprocessor.py) ─────────\n",
    "\n",
    "STOP_WORDS = {\"a\", \"an\", \"the\", \"and\", \"or\", \"but\", \"in\", \"on\", \"at\", \"to\", \"for\", \"of\", \"with\", \"by\", \"from\"}\n",
    "\n",
    "def clean_text(text: str) -> str:\n",
    "    if not isinstance(text, str): return \"\"\n",
    "    text = text.lower()\n",
    "    text = text.translate(str.maketrans(\"\", \"\", string.punctuation))\n",
    "    tokens = [t for t in text.split() if t not in STOP_WORDS and len(t) > 1]\n",
    "    return \" \".join(tokens)\n",
    "\n",
    "def build_job_corpus(job: dict) -> str:\n",
    "    # Title and skills are weighted 3x by repetition\n",
    "    text = f\"{job['title']} {job['title']} {job['title']} \" \\\n",
    "           f\"{' '.join(job['skills'])} {' '.join(job['skills'])} {' '.join(job['skills'])} \" \\\n",
    "           f\"{job['dept']} {job['company']} {job['description']}\"\n",
    "    return clean_text(text)\n",
    "\n",
    "def build_user_query(user: dict) -> str:\n",
    "    # User skills are weighted heavily\n",
    "    text = f\"{user['title']} {user['title']} \" \\\n",
    "           f\"{' '.join(user['skills'])} {' '.join(user['skills'])} {' '.join(user['skills'])} \" \\\n",
    "           f\"{user['bio']}\"\n",
    "    return clean_text(text)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Setup Sample Data\n",
    "We use a subset of the demo jobs and a sample candidate profile."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "jobs = [\n",
    "    {\n",
    "        \"id\": 1, \"title\": \"Senior ML Engineer\", \"company\": \"Stripe\", \"dept\": \"AI Research\",\n",
    "        \"skills\": [\"Python\", \"PyTorch\", \"NLP\", \"System Design\"],\n",
    "        \"description\": \"Lead our payment flow anomaly detection using state-of-the-art BERT models.\"\n",
    "    },\n",
    "    {\n",
    "        \"id\": 2, \"title\": \"Frontend Developer\", \"company\": \"Figma\", \"dept\": \"Product\",\n",
    "        \"skills\": [\"React\", \"TypeScript\", \"Tailwind\", \"Wasm\"],\n",
    "        \"description\": \"Build delightful multiplayer experiences for creative professionals.\"\n",
    "    },\n",
    "    {\n",
    "        \"id\": 3, \"title\": \"Data Scientist\", \"company\": \"Airbnb\", \"dept\": \"Data Science\",\n",
    "        \"skills\": [\"Python\", \"SQL\", \"Statistics\", \"PyTorch\"],\n",
    "        \"description\": \"Optimize our search ranking using causal inference and deep learning.\"\n",
    "    }\n",
    "]\n",
    "\n",
    "user = {\n",
    "    \"name\": \"Alex Chen\",\n",
    "    \"title\": \"AI Specialist\",\n",
    "    \"skills\": [\"Python\", \"Machine Learning\", \"NLP\", \"PyTorch\", \"TensorFlow\", \"Docker\"],\n",
    "    \"bio\": \"Passionate about ML and NLP, building scalable AI systems.\"\n",
    "}"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Implement Ranking Logic\n",
    "We replicate the calculation steps for each algorithm."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class DemoRecommender:\n",
    "    def __init__(self, jobs):\n",
    "        self.jobs = jobs\n",
    "        self.vectorizer = TfidfVectorizer()\n",
    "        self.job_corpus = [build_job_corpus(j) for j in jobs]\n",
    "        self.tfidf_matrix = self.vectorizer.fit_transform(self.job_corpus)\n",
    "\n",
    "    def recommend_tfidf(self, user_query):\n",
    "        q_vec = self.vectorizer.transform([user_query])\n",
    "        sims = cosine_similarity(q_vec, self.tfidf_matrix).flatten()\n",
    "        # Scale similarity to 0-100 range similar to the UI\n",
    "        scores = [int(min(99, max(40, s * 220))) for s in sims]\n",
    "        return scores\n",
    "\n",
    "    def recommend_keyword(self, user_query):\n",
    "        q_tokens = set(user_query.split())\n",
    "        scores = []\n",
    "        for job in self.jobs:\n",
    "            j_tokens = set(\" \".join(job['skills']).lower().split())\n",
    "            union = q_tokens | j_tokens\n",
    "            inter = q_tokens & j_tokens\n",
    "            jaccard = len(inter) / len(union) if union else 0\n",
    "            scores.append(int(min(99, max(35, jaccard * 300))))\n",
    "        return scores\n",
    "\n",
    "rec = DemoRecommender(jobs)\n",
    "user_q = build_user_query(user)\n",
    "\n",
    "tfidf_scores = rec.recommend_tfidf(user_q)\n",
    "keyword_scores = rec.recommend_keyword(user_q)\n",
    "hybrid_scores = [int(0.7 * t + 0.3 * k) for t, k in zip(tfidf_scores, keyword_scores)]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Results Visualization\n",
    "Compare outcomes for different ranking strategies."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = pd.DataFrame({\n",
    "    \"Job Title\": [j['title'] for j in jobs],\n",
    "    \"Company\": [j['company'] for j in jobs],\n",
    "    \"TF-IDF Score\": tfidf_scores,\n",
    "    \"Keyword Score\": keyword_scores,\n",
    "    \"Hybrid Score\": hybrid_scores\n",
    "})\n",
    "\n",
    "print(f\"Recommendation results for {user['name']} ({user['title']}):\")\n",
    "results.sort_values(\"Hybrid Score\", ascending=False)"
   ]
  }\n",
 ],\n",
