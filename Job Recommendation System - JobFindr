    "---\n",
    "## 3. Text Preprocessing (`app/ml/preprocessor.py`)\n",
    "\n",
    "| Function | Key logic |\n",
    "|---|---|\n",
    "| `clean_text(text)` | lowercase, strip punct/URLs, remove stop-words |\n",
    "| `build_job_corpus(job)` | `title*3 + skills*3 + dept + company + description` → `clean_text()` |\n",
    "| `build_user_profile_text(user)` | `title*2 + skills*3 + bio` → `clean_text()` |\n",
    "\n",
    "**Why repeat title/skills 3x?** TF-IDF rewards term frequency within a document. Repeating key fields inflates their TF counts so cosine similarity prioritises role and skill alignment over description noise.\n",
    "\n",
    "**Custom stop-words:** Standard English stop-words plus job-ad noise (`job, find, opportunity, work, join, team, growth, experience`) — words that appear in nearly every listing and would pollute IDF."
   ]
  },

  {
   "cell_type": "code",
   "execution_count": null,
   "id": "s3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exact replica of app/ml/preprocessor.py\n",
    "\n",
    "STOP_WORDS = {\n",
    "    'a','an','the','and','or','but','in','on','at','to','for','of','with','by',\n",
    "    'from','up','about','into','through','during','is','are','was','were','be',\n",
    "    'been','being','have','has','had','do','does','did','will','would','could',\n",
    "    'should','may','might','shall','can','need','dare','ought','used','as','this',\n",
    "    'that','these','those','it','its','we','you','they','he','she','our','your',\n",
    "    'their','my','his','her','which','who','whom','what','when','where','why','how',\n",
    "    'all','both','each','few','more','most','other','some','such','no','not','only',\n",
    "    'same','so','than','too','very','just','over','also','i','me','us',\n",
    "    'job','find','opportunity','work','join','team','growth','global','experience'\n",
    "}\n",
    "\n",
    "def clean_text(text):\n",
    "    if not isinstance(text, str): return ''\n",
    "    text = text.lower()\n",
    "    text = text.replace('/', ' ').replace('-', ' ')\n",
    "    text = re.sub(r'http\\S+|www\\S+', '', text)\n",
    "    text = re.sub(r'[!\"$%&\\'()*,\\.:;<=>?@\\[\\\\\\]^_`{|}~]', ' ', text)\n",
    "    tokens = text.split()\n",
    "    tokens = [t for t in tokens if t not in STOP_WORDS and not t.isdigit() and len(t) > 1]\n",
    "    return ' '.join(tokens)\n",
    "\n",
    "def build_job_corpus(job):\n",
    "    title  = str(job.get('title','') or '')\n",
    "    skills = ' '.join([str(s) for s in job.get('skills',[])])\n",
    "    dept   = str(job.get('dept','') or '')\n",
    "    desc   = str(job.get('description','') or '')\n",
    "    comp   = str(job.get('company','') or '')\n",
    "    return clean_text(f'{title} {title} {title} {skills} {skills} {skills} {dept} {comp} {desc}')\n",
    "\n",
    "def build_user_profile_text(user):\n",
    "    title  = str(user.get('title','') or '')\n",
    "    skills = ' '.join([str(s) for s in user.get('skills',[])])\n",
    "    bio    = str(user.get('bio','') or '')\n",
    "    return clean_text(f'{title} {title} {skills} {skills} {skills} {bio}')\n",
    "\n",
    "# Demo\n",
    "sample = df.iloc[0].to_dict()\n",
    "corpus_str = build_job_corpus(sample)\n",
    "print(f'Job:  {sample[\"title\"]} @ {sample[\"company\"]}')\n",
    "print(f'Dept: {sample[\"dept\"]}')\n",
    "print(f'\\nCorpus (first 300 chars):')\n",
    "print(f'  {corpus_str[:300]}')\n",
    "print(f'\\nTotal tokens: {len(corpus_str.split())}')"
   ]
