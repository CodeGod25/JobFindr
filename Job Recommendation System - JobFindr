    "# Panel 2: Radar charts — 5-axis breakdown\n",
    "def draw_radar(ax, scores, title, color='#6366f1'):\n",
    "    cats = [c.replace('_','\\n') for c in scores.keys()]\n",
    "    vals = list(scores.values())\n",
    "    N = len(cats)\n",
    "    angles = np.linspace(0, 2*np.pi, N, endpoint=False).tolist()\n",
    "    vals += vals[:1]; angles += angles[:1]\n",
    "    ax.set_theta_offset(np.pi/2); ax.set_theta_direction(-1)\n",
    "    ax.set_xticks(angles[:-1]); ax.set_xticklabels(cats, fontsize=7.5, color='#94a3b8')\n",
    "    ax.set_ylim(0,100); ax.set_yticks([20,40,60,80,100])\n",
    "    ax.set_yticklabels(['20','40','60','80','100'], fontsize=6, color='#475569')\n",
    "    ax.spines['polar'].set_color('#334155'); ax.grid(color='#334155', alpha=0.5)\n",
    "    ax.plot(angles, vals, 'o-', lw=2.5, color=color, markersize=5)\n",
    "    ax.fill(angles, vals, alpha=0.2, color=color)\n",
    "    for a, v in zip(angles[:-1], vals[:-1]):\n",
    "        ax.text(a, v+8, str(v), ha='center', va='center', fontsize=7, fontweight='bold', color=color)\n",
    "    ax.set_facecolor('#1e293b')\n",
    "    ax.set_title(title, size=9, pad=18, fontweight='bold', color='#f1f5f9')\n",
    "\n",
    "radar_colors = ['#6366f1','#22d3ee','#f472b6']\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 6), subplot_kw={'polar':True})\n",
    "fig.patch.set_facecolor('#0f172a')\n",
    "fig.suptitle('5-Axis Score Breakdown — Top Hybrid Match', fontsize=13,\n",
    "             fontweight='bold', color='#c7d2fe', y=1.04)\n",
    "\n",
    "for ax, user, col in zip(axes, USERS, radar_colors):\n",
    "    top = recommend_hybrid(user, JOBS, vectorizer, tfidf_matrix, top_n=1)[0]\n",
    "    job = next(j for j in JOBS if j['id']==top['id'])\n",
    "    bd = get_score_breakdown(user, job, vectorizer, tfidf_matrix, JOBS)\n",
    "    draw_radar(ax, bd, f\"{user['name']}\\nvs {str(job['title'])[:22]}\", color=col)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
